pipeline{
    agent any 
    environment{
        PYTHON = 'C:\\Users\\pooja\\AppData\\Local\\Programs\\Python\\Python314\\python.exe
' 
    }
    stages {
        stage ('checkout code'){
            steps{   
                 checkout scm
            }

        }
        stage('show python version'){
            steps{
                bat "${env.PYTHON} --version"
            }

        }
        stage('run extract.py'){
            steps{
                bat "${env.PYTHON} extract.py"

        }

    }
}
}